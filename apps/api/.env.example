APP_ENV=development
APP_URL=http://localhost:4000
API_PORT=4000
FRONTEND_URL=http://localhost:3000

# Database (Supabase local via Supabase CLI)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
# SSL: set to 'false' ONLY for managed DBs with self-signed certs (e.g. Supabase pooler)
# Default is 'true' (validates server certificate) — never set false for raw Postgres
DB_SSL_REJECT_UNAUTHORIZED=true

# JWT
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_EXPIRES_MINUTES=1440

# Google OAuth (obtain from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis
REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Cloudflare R2 (placeholder — not yet created)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
