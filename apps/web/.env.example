NEXT_PUBLIC_APP_NAME="Community Hyper Marketplace"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_DEFAULT_LOCALE="th"
NEXT_PUBLIC_SUPPORTED_LOCALES="th,en"

# Google OAuth (obtain from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# Cloudflare R2 (public access URL if using public bucket)
NEXT_PUBLIC_STORAGE_URL=""

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=""

# Feature flags
NEXT_PUBLIC_ENABLE_DARK_MODE="true"

# SEO / AI-SEO
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# Security — filled automatically from deployment platform (Vercel/Nginx)
# CSP nonce generation, HSTS, etc. handled in next.config.ts
